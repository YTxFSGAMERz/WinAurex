Windows Registry Editor Version 5.00

; WinAurex Windows Optimization Framework
; Tweaks\Input\Enable Mouse Acceleration.reg
; Re-enables Enhance Pointer Precision and deletes custom curves to restore default Windows scaling.

[HKEY_CURRENT_USER\Control Panel\Mouse]
"MouseSpeed"="1"
"MouseThreshold1"="6"
"MouseThreshold2"="10"
"SmoothMouseXCurve"=-
"SmoothMouseYCurve"=-
