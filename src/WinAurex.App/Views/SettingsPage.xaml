<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinAurex_App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Spacing="{StaticResource SpacingLarge}">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextStyle}" />
            
            <Button Content="Set Dark Theme" Click="ToggleTheme_Click" Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
