---
// HeadSEO.astro — Starlight Head override that adds JSON-LD + OG tags
// MUST import and render the default Head component to preserve all built-in tags
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

// JSON-LD Structured Data for SEO
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "WinAurex",
  "url": "https://winaurex.vercel.app",
  "description": "Free open-source Windows 11 optimization framework featuring a native C# WPF GUI Dashboard. Debloat, boost gaming FPS, build custom ISOs, and disable telemetry effortlessly.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://winaurex.vercel.app/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  },
  "author": {
    "@type": "Person",
    "name": "Farhan",
    "url": "https://github.com/YTxFSGAMERz"
  }
};

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "WinAurex",
  "operatingSystem": "Windows 11, Windows 10",
  "applicationCategory": "UtilitiesApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": "Free open-source Windows 11 optimization toolkit featuring a compiled C# .NET WPF dashboard to debloat, boost gaming performance, build custom ISOs, and disable telemetry natively.",
  "url": "https://winaurex.vercel.app",
  "downloadUrl": "https://github.com/YTxFSGAMERz/WinAurex",
  "softwareVersion": "1.0",
  "author": {
    "@type": "Person",
    "name": "Farhan"
  }
};

import heroImage from '../assets/houston.webp';
const isHomepage = Astro.props.slug === '' || Astro.props.slug === undefined;
---

<!-- Render ALL default Starlight head tags first -->
<Default {...Astro.props}><slot /></Default>

<!-- Append custom SEO tags -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
<meta property="og:image" content="https://winaurex.vercel.app/og-image.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://winaurex.vercel.app/og-image.png" />
<meta name="google-site-verification" content="E7D16t2Y65R_0-WG7qXbGPU2dksmCFIorHa5b5RkKbQ" />
{isHomepage && <link rel="preload" href={heroImage.src} as="image" type="image/webp" fetchpriority="high" />}

<Analytics />
<SpeedInsights />
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6005307432943157" crossorigin="anonymous"></script>
